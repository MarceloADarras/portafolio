---
import { Icon } from 'astro-icon/components'
interface Props {
    imagen: string,
    titulo: string,
    descripcion: string,
    tecnologias: string[],
    linkGithub: string,
}

const {imagen, titulo ,descripcion, tecnologias , linkGithub} = Astro.props
---

 <section>
    <div class="flex flex-col justify-center w-full md:min-w-[500px] md:max-w-sm border border-black rounded-lg shadow'md bg-white gap-2 p-2">
        <img src={imagen} alt="No image">
        <hr>
        <h1 class="font-bold text-xl">{titulo}</h1>
        <p class="text-l">{descripcion}</p>
        <div class="flex flex-wrap gap-3 items-center">
            {tecnologias.map((tech) => (
                <div class="p-1.5 bg-slate-800 rounded-md border border-slate-700" title={tech.split(':')[1] || tech}>
                    <Icon name={tech} class="w-6 h-6 text-white"/>
                </div>
            ))}
        </div>
        <div class="flex flex-row">
            <Icon name="simple-icons:github" class="w-4 h-4"/> <p> :{linkGithub}</p>
        </div>


    </div>
 </section>