---
import { Icon } from 'astro-icon/components'
interface Props {
    imagen: string,
    titulo: string,
    descripcion: string,
    tecnologias: string[],
    linkGithub: string,
    linkProyecto: string,
}

const {imagen, titulo ,descripcion, tecnologias , linkGithub, linkProyecto} = Astro.props
---

 <section>
    
    <div class="flex flex-col justify-center w-full md:min-w-[500px] md:max-w-sm border border-black rounded-lg shadow'md bg-white gap-2 p-2 hover:scale-105 transition-all duration-200">
        <a href={linkProyecto} class="relative group block w-full h-full overflow-hidden rounded-lg">
            <img src={imagen} alt="No image" class="hover:brightness-75 duration-200">
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <svg 
                xmlns="http://www.w3.org/2000/svg" 
                class="h-10 w-10 text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300" 
                fill="none" 
                viewBox="0 0 24 24" 
                stroke="currentColor" 
                stroke-width="2"
                >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                </svg>
            </div>
        </a>
        <hr>
        <h1 class="font-bold text-xl">{titulo}</h1>
        <p class="text-l">{descripcion}</p>
        <div class="flex flex-wrap gap-3 items-center">
            {tecnologias.map((tech) => (
                <div class="p-1.5 bg-slate-800 rounded-md border border-slate-700" title={tech.split(':')[1] || tech}>
                    <Icon name={tech} class="w-6 h-6 text-white"/>
                </div>
            ))}
        </div>
        <a href={linkGithub}>
            <div class="hover:text-blue-500 duration-100">
                 <p class="flex"> <Icon name="simple-icons:github" class="mt-1 mr-1 mb-1 w-[20px] h-auto"/>: {linkGithub}</p>
            </div>
        </a>


    </div>
    
 </section>