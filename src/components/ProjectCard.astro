---
import { Icon } from 'astro-icon/components'

interface Props {
    imagen?: string,
    titulo: string,
    descripcion?: string,
    tecnologias?: string[],
    linkGithub?: string,
    linkProyecto?: string,
    isPlaceholder?: boolean,
}

const {
    imagen = '',
    titulo,
    descripcion = '',
    tecnologias = [],
    linkGithub = '',
    linkProyecto = '',
    isPlaceholder = false
} = Astro.props

const esPlaceholder = isPlaceholder || imagen === "No Image" || (!linkGithub && !linkProyecto && !descripcion);
---

<section class="group h-full">
    {esPlaceholder ? (
        <div class="relative flex flex-col justify-between w-full max-w-sm h-full bg-slate-900/60 border border-dashed border-teal-500/40 hover:border-teal-400/80 rounded-2xl p-4 shadow-xl hover:shadow-2xl hover:shadow-teal-500/15 transition-all duration-500 backdrop-blur-sm overflow-hidden">
            
            {/* Glow decorativo superior */}
            <div class="absolute -top-12 -right-12 w-28 h-28 bg-teal-500/10 rounded-full blur-2xl group-hover:bg-teal-400/20 transition-all duration-500"></div>

            {/* Bloque Superior */}
            <div class="space-y-4 relative z-10">
                
                {/* Vista Previa Animada de Carga / En Desarrollo */}
                <div class="relative w-full aspect-video overflow-hidden rounded-xl bg-slate-950/90 border border-slate-800/90 flex flex-col items-center justify-center p-4 group-hover:border-teal-500/30 transition-all duration-300">
                    
                    {/* Efecto Cuadrícula / Glow Radial de Fondo */}
                    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(45,212,191,0.12),transparent_70%)]"></div>
                    
                    {/* Shimmer Wave Animado */}
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-teal-400/10 to-transparent -translate-x-full animate-[shimmer_2.5s_infinite] pointer-events-none"></div>

                    {/* Loader Central Dinámico */}
                    <div class="relative flex items-center justify-center my-auto">
                        {/* Anillo giratorio punteado exterior */}
                        <div class="w-16 h-16 rounded-full border-2 border-dashed border-teal-400/50 animate-[spin_8s_linear_infinite]"></div>
                        
                        {/* Icono central pulsante */}
                        <div class="absolute inset-0 flex items-center justify-center">
                            <div class="p-2.5 bg-slate-900/90 border border-teal-500/30 rounded-full shadow-lg shadow-teal-500/20 group-hover:scale-110 transition-transform duration-300">
                                <Icon name="lucide:loader-2" class="w-6 h-6 text-teal-300 animate-spin" />
                            </div>
                        </div>
                    </div>

                    {/* Badge "En construcción" inferior con punto 'ping' */}
                    <div class="mt-auto relative z-10">
                        <span class="inline-flex items-center gap-2 px-3 py-1 bg-slate-900/90 border border-teal-500/30 text-teal-300 rounded-full text-xs font-semibold backdrop-blur-md shadow-md">
                            <span class="relative flex h-2 w-2">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-teal-400"></span>
                            </span>
                            En desarrollo...
                        </span>
                    </div>
                </div>

                {/* Título y Descripción */}
                <div class="space-y-2">
                    <h3 class="font-bold text-xl text-white tracking-tight group-hover:text-teal-300 transition-colors flex items-center gap-2">
                        {titulo}
                        <Icon name="lucide:sparkles" class="w-4 h-4 text-teal-400 animate-pulse" />
                    </h3>
                    <p class="text-sm text-slate-400 leading-relaxed">
                        {descripcion || "Actualmente diseñando y construyendo nuevas aplicaciones web full-stack. ¡Vuelve pronto para ver las novedades!"}
                    </p>
                </div>
            </div>

            {/* Bloque Inferior: Skeletons & Estado */}
            <div class="space-y-4 pt-4 border-t border-slate-800/80 mt-4 relative z-10">
                
                {/* Chips de Tecnologías (Skeleton Animado) */}
                <div class="flex flex-wrap gap-2 items-center">
                    {tecnologias && tecnologias.length > 0 ? (
                        tecnologias.map((tech) => (
                            <div 
                                class="p-1.5 bg-slate-800/60 hover:bg-slate-800 rounded-lg border border-slate-700/60 transition-colors" 
                                title={tech.split(':')[1] || tech}
                            >
                                <Icon name={tech} class="w-5 h-5 text-slate-300 hover:text-white transition-colors"/>
                            </div>
                        ))
                    ) : (
                        /* Skeletons pulsantes de tecnologías */
                        <div class="flex items-center gap-2">
                            <div class="p-1.5 bg-slate-800/50 rounded-lg border border-slate-700/40 animate-pulse">
                                <Icon name="lucide:code-2" class="w-5 h-5 text-teal-400/60" />
                            </div>
                            <div class="p-1.5 bg-slate-800/50 rounded-lg border border-slate-700/40 animate-pulse delay-100">
                                <Icon name="lucide:database" class="w-5 h-5 text-teal-400/60" />
                            </div>
                            <div class="p-1.5 bg-slate-800/50 rounded-lg border border-slate-700/40 animate-pulse delay-200">
                                <Icon name="lucide:layers" class="w-5 h-5 text-teal-400/60" />
                            </div>
                            <span class="text-xs text-slate-500 font-medium ml-1">Nuevas tecnologías</span>
                        </div>
                    )}
                </div>

                {/* Botón de Estado / Próximamente */}
                <div class="pt-1">
                    <div class="inline-flex items-center gap-2 text-xs font-medium text-teal-300/80 bg-slate-800/40 border border-slate-800 px-3.5 py-2 rounded-xl w-full justify-center shadow-inner cursor-default">
                        <Icon name="lucide:clock" class="w-4 h-4 text-teal-400 animate-spin" />
                        <span class="truncate">Próximamente disponible</span>
                    </div>
                </div>
            </div>
        </div>
    ) : (
        <div class="flex flex-col justify-between w-full max-w-sm h-full bg-slate-900/90 border border-slate-800 hover:border-slate-700 rounded-2xl p-4 shadow-xl hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-300 backdrop-blur-sm">
            
            {/* Bloque Superior: Imagen e Información */}
            <div class="space-y-4">
                
                {/* Vista Previa de Imagen con Enlace */}
                <a href={linkProyecto || linkGithub} target="_blank" class="relative block w-full aspect-video overflow-hidden rounded-xl bg-slate-950 border border-slate-800/80 group-hover:border-slate-700 transition-colors">
                    <img 
                        src={imagen} 
                        alt={titulo} 
                        class="w-full h-full object-cover group-hover:scale-105 group-hover:brightness-90 transition-all duration-500 ease-out"
                    />
                    
                    {/* Overlay con icono de enlace al hacer hover */}
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-3">
                        <span class="text-xs font-medium text-slate-200 flex items-center gap-1.5 bg-slate-900/80 px-2.5 py-1 rounded-md backdrop-blur-md border border-slate-700/50">
                            <Icon name="lucide:external-link" class="w-3.5 h-3.5 text-blue-400" />
                            Ver proyecto
                        </span>
                    </div>
                </a>

                {/* Título y Descripción */}
                <div class="space-y-2">
                    <h3 class="font-bold text-xl text-white tracking-tight group-hover:text-blue-400 transition-colors">
                        {titulo}
                    </h3>
                    <p class="text-sm text-slate-400 leading-relaxed line-clamp-2">
                        {descripcion}
                    </p>
                </div>
            </div>

            {/* Bloque Inferior: Tecnologías y Enlace a GitHub */}
            <div class="space-y-4 pt-4 border-t border-slate-800/80 mt-4">
                
                {/* Lista de Tecnologías */}
                <div class="flex flex-wrap gap-2 items-center">
                    {tecnologias.map((tech) => (
                        <div 
                            class="p-1.5 bg-slate-800/60 hover:bg-slate-800 rounded-lg border border-slate-700/60 transition-colors" 
                            title={tech.split(':')[1] || tech}
                        >
                            <Icon name={tech} class="w-5 h-5 text-slate-300 hover:text-white transition-colors"/>
                        </div>
                    ))}
                </div>

                {/* Botón de GitHub */}
                <div class="pt-1">
                    <a 
                        href={linkGithub} 
                        target="_blank" 
                        class="inline-flex items-center gap-2 text-xs font-medium text-slate-300 hover:text-white bg-slate-800/60 hover:bg-slate-800 px-3.5 py-2 rounded-xl border border-slate-700/60 hover:border-slate-600 transition-all w-full justify-center"
                    >
                        <Icon name="simple-icons:github" class="w-4 h-4 shrink-0 text-slate-200" />
                        <span class="truncate">Ver código en GitHub</span>
                    </a>
                </div>
            </div>
        </div> 
    )}
</section>


