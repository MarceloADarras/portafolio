---
import { Icon } from 'astro-icon/components'

interface Props {
    imagen: string,
    titulo: string,
    descripcion: string,
    tecnologias: string[],
    linkGithub: string,
    linkProyecto: string,
}

const {imagen, titulo ,descripcion, tecnologias , linkGithub, linkProyecto} = Astro.props

---
<section class="group h-full">
    <!-- Contenedor Principal de la Tarjeta -->
    <div class="flex flex-col justify-between w-full max-w-sm h-full bg-slate-900/90 border border-slate-800 hover:border-slate-700 rounded-2xl p-4 shadow-xl hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-300 backdrop-blur-sm">
        
        <!-- Bloque Superior: Imagen e Información -->
        <div class="space-y-4">
            
            <!-- Vista Previa de Imagen con Enlace -->
            <a href={linkProyecto || linkGithub} target="_blank" class="relative block w-full aspect-video overflow-hidden rounded-xl bg-slate-950 border border-slate-800/80 group-hover:border-slate-700 transition-colors">
                <img 
                    src={imagen} 
                    alt={`Vista previa de ${titulo}`} 
                    class="w-full h-full object-cover group-hover:scale-105 group-hover:brightness-90 transition-all duration-500 ease-out"
                />
                
                <!-- Overlay con icono de enlace al hacer hover -->
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-3">
                    <span class="text-xs font-medium text-slate-200 flex items-center gap-1.5 bg-slate-900/80 px-2.5 py-1 rounded-md backdrop-blur-md border border-slate-700/50">
                        <Icon name="lucide:external-link" class="w-3.5 h-3.5 text-blue-400" />
                        Ver proyecto
                    </span>
                </div>
            </a>

            <!-- Título y Descripción -->
            <div class="space-y-2">
                <h3 class="font-bold text-xl text-white tracking-tight group-hover:text-blue-400 transition-colors">
                    {titulo}
                </h3>
                <p class="text-sm text-slate-400 leading-relaxed line-clamp-2">
                    {descripcion}
                </p>
            </div>
        </div>

        <!-- Bloque Inferior: Tecnologías y Enlace a GitHub -->
        <div class="space-y-4 pt-4 border-t border-slate-800/80 mt-4">
            
            <!-- Lista de Tecnologías -->
            <div class="flex flex-wrap gap-2 items-center">
                {tecnologias.map((tech) => (
                    <div 
                        class="p-1.5 bg-slate-800/60 hover:bg-slate-800 rounded-lg border border-slate-700/60 transition-colors" 
                        title={tech.split(':')[1] || tech}
                    >
                        <Icon name={tech} class="w-5 h-5 text-slate-300 hover:text-white transition-colors"/>
                    </div>
                ))}
            </div>

            <!-- Botón de GitHub -->
            <div class="pt-1">
                <a 
                    href={linkGithub} 
                    target="_blank" 
                    class="inline-flex items-center gap-2 text-xs font-medium text-slate-300 hover:text-white bg-slate-800/60 hover:bg-slate-800 px-3.5 py-2 rounded-xl border border-slate-700/60 hover:border-slate-600 transition-all w-full justify-center"
                >
                    <Icon name="simple-icons:github" class="w-4 h-4 shrink-0 text-slate-200" />
                    <span class="truncate">Ver código en GitHub</span>
                </a>
            </div>
        </div>
    </div> 
</section>

