---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import imagenPerfil from '/public/media/marcelo_darras_pf.png';
import { Icon } from 'astro-icon/components';
import Preview from '/public/media/preview_kuma.png';
import Preview2 from '/public/media/preview_bey.png';

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
	<div class="mt-[5%] flex flex-row justify-center items-center gap-4">
		<img class="relative z-10 w-48 h-48 md:w-56 md:h-56 object-cover rounded-full shadow-lg animate-center-then-left" src={imagenPerfil.src} alt="imagen perfil">
		<div class="relative z-0 text-center md:text-left space-y-3 animate-text-reveal">
			<h1 class="text-3xl md:text-4xl font-bold text-white tracking-tight">
				¡Hola!, soy <span class="text-blue-400">Marcelo Darras</span>
			</h1>
			<p class="text-lg text-slate-400 font-medium">
				Ingeniero en Informática
			</p>
			<p class="text-slate-400 max-w-xl leading-relaxed">
				Soy un profesional enérgico, comprometido y con gran disposición para enfrentar desafíos técnicos. 
				A continuación, te invito a explorar el repertorio de proyectos en los que he trabajado.
			</p>
		
    	</div>

	</div>
    <div class="flex justify-center my-8 sticky top-4 z-50 px-4 aparecer-lado">
        <ul class="flex flex-wrap justify-center items-center gap-1 md:gap-2 bg-slate-900/80 border border-slate-800 backdrop-blur-md p-1.5 rounded-2xl shadow-xl shadow-black/20 text-sm font-medium">
        <li>
            <a href="#experiencia" class="px-3 py-1.5 rounded-xl text-slate-300 hover:text-white hover:bg-slate-800/80 transition-all block">
                Experiencia
            </a>
        </li>
        <li>
            <a href="#proyectos" class="px-3 py-1.5 rounded-xl text-slate-300 hover:text-white hover:bg-slate-800/80 transition-all block">
                Proyectos
            </a>
        </li>
        <li>
            <a href="#lenguajes" class="px-3 py-1.5 rounded-xl text-slate-300 hover:text-white hover:bg-slate-800/80 transition-all block">
                Lenguajes
            </a>
        </li>
        <li>
            <a href="#frameworks" class="px-3 py-1.5 rounded-xl text-slate-300 hover:text-white hover:bg-slate-800/80 transition-all block">
                Frameworks
            </a>
        </li>
        <li>
            <a href="#herramientas" class="px-3 py-1.5 rounded-xl text-slate-300 hover:text-white hover:bg-slate-800/80 transition-all block">
                Herramientas
            </a>
        </li>
    </ul>
    </div>
    <div class="space-y-20 max-w-4xl mx-auto px-6 mb-20 aparecer-abajo">

        <!-- 3. Sección Experiencia (Estilo Timeline) -->
        <section id="experiencia" class="scroll-mt-24">
            <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight mb-8 flex items-center gap-3">
                <Icon name="lucide:briefcase" class="w-7 h-7 text-blue-400" />
                Experiencia Laboral
            </h2>

            <div class="relative border-l border-slate-800 ml-3 space-y-8 pl-6">
                <!-- Item Experiencia 1 -->
                <div class="relative group">
                    <!-- Punto en el Timeline -->
                    <div class="absolute -left-[31px] top-1.5 w-3 h-3 bg-blue-500 rounded-full border-4 border-slate-950 group-hover:scale-125 transition-transform"></div>
                    
                    <div class="bg-slate-900/60 border border-slate-800/80 p-5 rounded-2xl space-y-2 backdrop-blur-sm hover:border-slate-700 transition-colors">
                        <div class="flex flex-wrap justify-between items-start gap-2">
                            <h3 class="text-xl font-bold text-white">Solcor Chile</h3>
                            <span class="text-xs font-semibold text-blue-400 bg-blue-500/10 border border-blue-500/20 px-3 py-1 rounded-full">
                                Septiembre 2025 - Diciembre 2025
                            </span>
                        </div>
                        <p class="text-sm font-medium text-slate-300">Desarrollador Full-Stack (Practicante)</p>
                        <p class="text-slate-400 text-sm leading-relaxed">
                            Desarrollo e implementación de soluciones web utilizando <strong class="text-slate-200">Vue.js</strong> para interfaces dinámicas en el frontend y <strong class="text-slate-200">Django REST Framework</strong> para la arquitectura de APIs robustas en el backend.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- 4. Sección Proyectos -->
        <section id="proyectos" class="scroll-mt-24">
            <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight mb-8 flex items-center gap-3">
                <Icon name="lucide:folder-git-2" class="w-7 h-7 text-blue-400" />
                Proyectos Destacados
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 justify-items-center">
                <ProjectCard 
                    imagen={Preview.src}
                    titulo="Kuma Store"
                    descripcion="Una tienda e-commerce para la venta de artículos para mascotas con catálogo y gestión de productos."
                    tecnologias={["simple-icons:html5", "simple-icons:css3", "simple-icons:javascript", "simple-icons:django", "simple-icons:sqlite"]}
                    linkGithub="https://github.com/Marcelo200221/KumaStore.git"
                    linkProyecto="https://kumastore.onrender.com/"
                />
                
                <ProjectCard 
                    imagen={Preview2.src}
                    titulo="Project Bey"
                    descripcion="Página web interactiva creada como foro y comunidad para fanáticos de Beyblade."
                    tecnologias={["simple-icons:html5", "simple-icons:css3", "simple-icons:typescript", "simple-icons:django", "simple-icons:vuedotjs", "simple-icons:mysql"]}
                    linkGithub="https://github.com/Marcelo200221/Project-bey.git"
                    linkProyecto="https://project-beystory-one.vercel.app/home"
                />
            </div>
        </section>

        <!-- 5. Sección Lenguajes (Bento Grid) -->
        <section id="lenguajes" class="scroll-mt-24">
            <h2 class="text-2xl md:text-3xl font-bold text-white tracking-tight mb-8 flex items-center gap-3">
                <Icon name="lucide:code-2" class="w-7 h-7 text-blue-400" />
                Lenguajes de Programación
            </h2>

            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
                
                <!-- Python -->
                <div class="bg-slate-900/60 border border-slate-800 p-4 rounded-xl flex flex-col gap-3 hover:border-slate-700 transition-colors">
                    <div class="flex items-center justify-between">
                        <Icon name="simple-icons:python" class="w-6 h-6 text-blue-400" />
                        <span class="text-xs font-semibold bg-blue-500/10 text-blue-400 px-2 py-0.5 rounded-md">Avanzado</span>
                    </div>
                    <span class="font-bold text-white">Python</span>
                </div>

                <!-- JavaScript -->
                <div class="bg-slate-900/60 border border-slate-800 p-4 rounded-xl flex flex-col gap-3 hover:border-slate-700 transition-colors">
                    <div class="flex items-center justify-between">
                        <Icon name="simple-icons:javascript" class="w-6 h-6 text-yellow-400" />
                        <span class="text-xs font-semibold bg-blue-500/10 text-blue-400 px-2 py-0.5 rounded-md">Avanzado</span>
                    </div>
                    <span class="font-bold text-white">JavaScript</span>
                </div>

                <!-- HTML5 -->
                <div class="bg-slate-900/60 border border-slate-800 p-4 rounded-xl flex flex-col gap-3 hover:border-slate-700 transition-colors">
                    <div class="flex items-center justify-between">
                        <Icon name="simple-icons:html5" class="w-6 h-6 text-orange-500" />
                        <span class="text-xs font-semibold bg-blue-500/10 text-blue-400 px-2 py-0.5 rounded-md">Avanzado</span>
                    </div>
                    <span class="font-bold text-white">HTML</span>
                </div>

                <!-- CSS3 -->
                <div class="bg-slate-900/60 border border-slate-800 p-4 rounded-xl flex flex-col gap-3 hover:border-slate-700 transition-colors">
                    <div class="flex items-center justify-between">
                        <Icon name="simple-icons:css3" class="w-6 h-6 text-blue-500" />
                        <span class="text-xs font-semibold bg-blue-500/10 text-blue-400 px-2 py-0.5 rounded-md">Avanzado</span>
                    </div>
                    <span class="font-bold text-white">CSS</span>
                </div>

                <!-- PHP -->
                <div class="bg-slate-900/60 border border-slate-800 p-4 rounded-xl flex flex-col gap-3 hover:border-slate-700 transition-colors">
                    <div class="flex items-center justify-between">
                        <Icon name="simple-icons:php" class="w-6 h-6 text-indigo-400" />
                        <span class="text-xs font-semibold bg-slate-800 text-slate-300 px-2 py-0.5 rounded-md">Intermedio</span>
                    </div>
                    <span class="font-bold text-white">PHP</span>
                </div>

                <!-- Java -->
                <div class="bg-slate-900/60 border border-slate-800 p-4 rounded-xl flex flex-col gap-3 hover:border-slate-700 transition-colors">
                    <div class="flex items-center justify-between">
                        <Icon name="simple-icons:openjdk" class="w-6 h-6 text-red-400" />
                        <span class="text-xs font-semibold bg-slate-800 text-slate-300 px-2 py-0.5 rounded-md">Intermedio</span>
                    </div>
                    <span class="font-bold text-white">Java</span>
                </div>

            </div>
        </section>

    </div>
</Layout>

<style>
    /* Controlamos la línea de tiempo de la imagen en pantallas grandes (md) */
    @keyframes centerThenLeft {
        0% {
            opacity: 0;
            
            transform: translateY(50%); 
        }
        /* Del 0% al 40% del tiempo, la imagen solo aparece en el centro */
        /* Del 40% al 100%, la imagen se desplaza del centro a su posición original (izquierda) */
        100% {
            opacity: 1;
            
            transform: translateY(0);
        }
    }

    /* Animación del texto */
    @keyframes textReveal {
        0% {
            opacity: 0;
            transform: translateX(-50%);
        }
        100% {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* Aplicamos las animaciones solo en pantallas de escritorio (md) */
    @media (min-width: 768px) {
        .animate-center-then-left {
            /* Duración total de 2 segundos para que sea notorio y elegante */
            animation: centerThenLeft 1.0s cubic-bezier(0.25, 1, 0.5, 1) forwards;
            
        }

        .animate-text-reveal {
            opacity: 0;
            /* El texto aparece justo cuando la imagen empieza a moverse (40% de 2s = 0.8s) */
            animation: textReveal 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
            animation-delay: 0.5s; 
        }
    }

    /* En celulares, para evitar problemas de espacio, hacemos una aparición simple hacia abajo */
    @media (max-width: 767px) {
        @keyframes fadeInSimple {
            0% { opacity: 0; transform: translateY(10px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        .animate-center-then-left {
            animation: fadeInSimple 1s ease forwards;
        }
        .animate-text-reveal {
            opacity: 0;
            animation: fadeInSimple 1s ease forwards;
            animation-delay: 0.4s;
        }
    }

    @keyframes UpThenDown {
        0% {
            opacity: 0;
            transform: translateY(-25%);
        }
        100% {
            opacity: 1;
            transform: translate(0);
        }
    }

    @keyframes sideThenCenter {
        0% {
            opacity: 0;
            transform: translateX(-25%);
        }
        100% {
            opacity: 1;
            transform: translate(0);
        }
    }

    @media (min-width: 768px) {
        .aparecer-abajo{
            opacity: 0;
            animation: UpThenDown 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
            animation-delay: 2s;
        }

        .aparecer-lado {
            opacity: 0;
            animation: sideThenCenter 1s cubic-bezier(0.25, 1, 0.5, 1) forwards;
            animation-delay: 1s;
        }
    }
</style>
